Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Mumin", "=", 
   RowBox[{"-", "4.0"}]}], ";", 
  RowBox[{"Mumax", "=", "2.0"}], ";", 
  RowBox[{"nMu", "=", "60"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"T", "=", "1.0"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"VbisMin", "=", "1.0"}], ";", 
  RowBox[{"VbisMax", "=", "6.0"}], ";", 
  RowBox[{"nbis", "=", "18"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vplotmin", "=", "2.0"}], ";", 
   RowBox[{"Vplotmax", "=", "6.0"}], ";", 
   RowBox[{"nV", "=", "120"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"del", "=", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}], ";", 
   RowBox[{"mit", "=", "20"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Step"}]}], " ", "1"}], ":", 
    RowBox[{
     RowBox[{"critical", " ", "line", " ", "Vc", 
      RowBox[{"(", "mu", ")"}], " ", "by", " ", 
      RowBox[{"bisection", "--"}]}], "-"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"iMu", "=", "0"}], ",", 
     RowBox[{"iMu", "<=", "nMu"}], ",", 
     RowBox[{"iMu", "++"}], ",", 
     RowBox[{
      RowBox[{"Mu", "=", 
       RowBox[{"Mumin", "+", 
        RowBox[{
         RowBox[{"iMu", "/", "nMu"}], " ", 
         RowBox[{"(", 
          RowBox[{"Mumax", "-", "Mumin"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"v1", "=", "VbisMin"}], ";", "\[IndentingNewLine]", 
      RowBox[{"v2", "=", "VbisMax"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"ib", "=", "1"}], ",", 
        RowBox[{"ib", "<=", "nbis"}], ",", 
        RowBox[{"ib", "++"}], ",", 
        RowBox[{
         RowBox[{"V", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"v1", "+", "v2"}], ")"}], "/", "2"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"pa", "=", "0.05"}], ";", 
         RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"m", "=", "0"}], ",", 
           RowBox[{"m", "<=", "mit"}], ",", 
           RowBox[{"m", "++"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"dfta", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{
                  RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"dftb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", 
                  RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"pa", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"dftb", "-", 
                RowBox[{"2", " ", "dfta"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"6", " ", "V"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"pb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"dfta", "-", 
                RowBox[{"2", " ", "dftb"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"6", " ", "V"}], ")"}]}]}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
