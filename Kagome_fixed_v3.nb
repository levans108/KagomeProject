 RowBox[{
  RowBox[{
   RowBox[{"del", "=", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}], ";", 
   RowBox[{"mit", "=", "20"}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
