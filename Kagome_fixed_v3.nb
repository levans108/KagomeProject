Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"FEt", "[", 
   RowBox[{"pa_", ",", "pb_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "n", ",", "n1", ",", "n2", ",", "ft", ",", "A", ",", "ev", ",", "i"}], 
     "}"}], ",", 
    RowBox[{
     RowBox[{"n", "=", "40"}], ";", "\[IndentingNewLine]", 
     RowBox[{"ft", "=", "0.0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"n1", "=", "0"}], ",", 
       RowBox[{"n1", "<", "n"}], ",", 
       RowBox[{"n1", "++"}], ",", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"n2", "=", "0"}], ",", 
          RowBox[{"n2", "<", "n"}], ",", 
          RowBox[{"n2", "++"}], ",", 
          RowBox[{
           RowBox[{"A", "=", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", "2"}], " ", "V", " ", "pa"}], ",", 
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"I", " ", "2", " ", "Pi", " ", 
                   RowBox[{"n2", "/", "n"}]}], "]"}]}], ",", 
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", 
                   RowBox[{"n1", "/", "n"}]}], "]"}]}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{
                   RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", 
                   RowBox[{"n2", "/", "n"}]}], "]"}]}], ",", 
                RowBox[{
                 RowBox[{"-", "2"}], " ", "V", " ", "pb"}], ",", 
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", 
                    RowBox[{"n1", "/", "n"}]}], "]"}], " ", 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", "I"}], " ", "2", " ", "Pi", " ", 
                    RowBox[{"n2", "/", "n"}]}], "]"}]}]}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{"Exp", "[", 
                  RowBox[{"I", " ", "2", " ", "Pi", " ", 
                   RowBox[{"n1", "/", "n"}]}], "]"}]}], ",", 
                RowBox[{
                 RowBox[{"-", "1"}], "-", 
                 RowBox[{
                  RowBox[{"Exp", "[", 
                   RowBox[{"I", " ", "2", " ", "Pi", " ", 
                    RowBox[{"n1", "/", "n"}]}], "]"}], " ", 
                  RowBox[{"Exp", "[", 
                   RowBox[{"I", " ", "2", " ", "Pi", " ", 
                    RowBox[{"n2", "/", "n"}]}], "]"}]}]}], ",", 
                RowBox[{"2", " ", "V", " ", 
                 RowBox[{"(", 
                  RowBox[{"pa", "+", "pb"}], ")"}]}]}], "}"}]}], "}"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"ev", "=", 
            RowBox[{"Eigenvalues", "[", "A", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"i", "=", "1"}], ",", 
             RowBox[{"i", "<=", "3"}], ",", 
             RowBox[{"i", "++"}], ",", 
             RowBox[{"ft", "+=", 
              RowBox[{
               RowBox[{"-", "T"}], " ", 
               RowBox[{
                RowBox[{"Log", "[", 
                 RowBox[{"1", "+", 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"ev", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", "mu"}], ")"}]}], "/",
                     "T"}], "]"}]}], "]"}], "/", 
                RowBox[{"n", "^", "2"}]}]}]}]}], "]"}], ";"}]}], "]"}], 
        ";"}]}], "]"}], ";", "\[IndentingNewLine]", "ft"}]}], 
   "]"}]}]], "Input",
