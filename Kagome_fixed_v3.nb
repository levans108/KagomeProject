Cell[BoxData[{
 RowBox[{
  RowBox[{"mu", "=", 
   RowBox[{"-", "0.5"}]}], ";", 
  RowBox[{"T", "=", "0.4"}], ";", 
  RowBox[{"Vmin", "=", "1.5"}], ";", 
  RowBox[{"Vmax", "=", "3.5"}], ";", 
  RowBox[{"nV", "=", "100"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"del", "=", "0.0000000001"}], ";", 
  RowBox[{"mit", "=", "200"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"iV", "=", "0"}], ",", 
   RowBox[{"iV", "<=", "nV"}], ",", 
   RowBox[{"iV", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"V", "=", 
     RowBox[{"Vmin", "+", 
      RowBox[{
       RowBox[{"iV", "/", "nV"}], "*", 
       RowBox[{"(", 
        RowBox[{"Vmax", "-", "Vmin"}], ")"}]}]}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"pa", "=", "0.05"}], ";", 
    RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"m", "=", "0"}], ",", 
      RowBox[{"m", "<=", "mit"}], ",", 
      RowBox[{"m", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dfta", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"FEt", "[", 
            RowBox[{
             RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
           RowBox[{"FEt", "[", 
            RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"dftb", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"FEt", "[", 
            RowBox[{"pa", ",", 
             RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
           RowBox[{"FEt", "[", 
            RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"pa", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"dftb", "-", 
            RowBox[{"2", " ", "dfta"}]}], ")"}], "/", "6"}], "/", "V"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"pb", "=", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"dfta", "-", 
            RowBox[{"2", " ", "dftb"}]}], ")"}], "/", "6"}], "/", "V"}]}], 
       ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"dela", "[", "iV", "]"}], "=", "pa"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"delb", "[", "iV", "]"}], "=", "pb"}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"delc", "[", "iV", "]"}], "=", 
     RowBox[{
      RowBox[{"-", "pa"}], "-", "pb"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{
      RowBox[{"iV", "/", "nV"}], "*", "100."}], "]"}]}]}], 
  "\[IndentingNewLine]", "]"}]}], "Input",
