             RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"dfta", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{
                  RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"dftb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", 
                  RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"pa", "=", 
