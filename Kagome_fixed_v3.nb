Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Step"}]}], " ", "3"}], ":", 
    RowBox[{
     RowBox[{"swap", " ", "axes", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"V", " ", "on", " ", "x"}], ",", 
         RowBox[{"mu", " ", "on", " ", "y"}]}], ")"}], "--"}]}], "-"}]}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"phasePlot3", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"vVals", "[", 
            RowBox[{"[", 
             RowBox[{"j", "+", "1"}], "]"}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"x", "=", "V"}], "*)"}], 
           RowBox[{"muVals", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
           RowBox[{"(*", 
            RowBox[{"y", "=", "\[Mu]"}], "*)"}], 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"vVals", "[", 
               RowBox[{"[", 
                RowBox[{"j", "+", "1"}], "]"}], "]"}], ">=", 
              RowBox[{"vcVals", "[", 
               RowBox[{"[", 
                RowBox[{"i", "+", "1"}], "]"}], "]"}]}], ",", "1", ",", "0"}],
             "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "nMu"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", "nV"}], "}"}]}], "]"}], ",", "1"}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"boundary", " ", "also", " ", "needs", " ", "swapping"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"critLineSwapped", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"vcVals", "[", 
          RowBox[{"[", 
           RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
         RowBox[{"muVals", "[", 
          RowBox[{"[", 
           RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "nMu"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"ListDensityPlot", "[", 
    RowBox[{"phasePlot3", ",", 
     RowBox[{"InterpolationOrder", "->", "0"}], ",", 
     RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
     RowBox[{"(*", 
      RowBox[{"swapped", " ", "color", " ", "scheme"}], "*)"}], 
     RowBox[{"ColorFunction", "->", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#", "==", "1"}], ",", 
          RowBox[{"Lighter", "[", 
           RowBox[{"Yellow", ",", "0.2"}], "]"}], ",", 
          RowBox[{"(*", "CDW", "*)"}], 
          RowBox[{"Darker", "[", 
           RowBox[{"Blue", ",", "0.7"}], "]"}]}], "       ", 
         RowBox[{"(*", "disordered", "*)"}], "]"}], "&"}], ")"}]}], ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<V\>\"", ",", "\"\<\[Mu]\>\""}], "}"}]}], ",", 
     RowBox[{"LabelStyle", "->", 
      RowBox[{"Directive", "[", "14", "]"}]}], ",", 
     RowBox[{"PlotRange", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Vplotmin", ",", "Vplotmax"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Mumin", ",", "Mumax"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "->", "1"}], ",", 
     RowBox[{"(*", 
      RowBox[{"nicer", " ", "ticks"}], "*)"}], 
     RowBox[{"FrameTicks", "->", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "Automatic"}], "}"}]}], ",", 
     RowBox[{"(*", 
      RowBox[{"cleaner", " ", "boundary", " ", "line"}], "*)"}], 
     RowBox[{"Epilog", "->", 
      RowBox[{"{", 
       RowBox[{"Black", ",", "Thick", ",", 
        RowBox[{"Line", "[", "critLineSwapped", "]"}]}], "}"}]}]}], 
    "]"}]}]}]], "Input",
