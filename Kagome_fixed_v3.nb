      RowBox[{"bisection", "--"}]}], "-"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"iMu", "=", "0"}], ",", 
     RowBox[{"iMu", "<=", "nMu"}], ",", 
     RowBox[{"iMu", "++"}], ",", 
     RowBox[{
      RowBox[{"Mu", "=", 
