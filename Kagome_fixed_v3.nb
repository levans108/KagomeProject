Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Mumin", "=", 
   RowBox[{"-", "4.0"}]}], ";", 
  RowBox[{"Mumax", "=", "2.0"}], ";", 
  RowBox[{"nMu", "=", "10"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"T", "=", "1.0"}], " ", ";"}], "\n", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"iMu", "=", "0"}], ",", 
    RowBox[{"iMu", "<=", "nMu"}], ",", 
    RowBox[{"iMu", "++"}], ",", 
    RowBox[{
     RowBox[{"Mu", "=", 
      RowBox[{"Mumin", "+", 
       RowBox[{
        RowBox[{"iMu", "/", "nMu"}], "*", 
        RowBox[{"(", 
         RowBox[{"Mumax", "-", "Mumin"}], ")"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Vmin", "=", "1.0"}], ";", 
     RowBox[{"Vmax", "=", "5.0"}], ";", 
     RowBox[{"nb", "=", "10"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"ib", "=", "1"}], ",", 
       RowBox[{"ib", "<=", "nb"}], ",", 
       RowBox[{"ib", "++"}], ",", 
       RowBox[{
        RowBox[{"V", "=", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Vmin", "+", "Vmax"}], ")"}], "/", "2"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"del", "=", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}]}], ";", 
        RowBox[{"mit", "=", "20"}], ";", 
        RowBox[{"pa", "=", "0.05"}], ";", 
        RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"m", "=", "0"}], ",", 
          RowBox[{"m", "<=", "mit"}], ",", 
          RowBox[{"m", "++"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
           RowBox[{
            RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"dfta", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"FEt", "[", 
                RowBox[{
                 RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
               RowBox[{"FEt", "[", 
                RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"dftb", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"FEt", "[", 
                RowBox[{"pa", ",", 
                 RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
               RowBox[{"FEt", "[", 
                RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
            "\[IndentingNewLine]", 
           RowBox[{"pa", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"dftb", "-", 
               RowBox[{"2", " ", "dfta"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"6", " ", "V"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
           
           RowBox[{"pb", "=", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"dfta", "-", 
               RowBox[{"2", " ", "dftb"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"6", " ", "V"}], ")"}]}]}], ";"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"d", " ", "=", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"pa", "-", 
              RowBox[{"a", "[", "m", "]"}]}], ")"}], "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"pb", "-", 
              RowBox[{"b", "[", "m", "]"}]}], ")"}], "^", "2"}]}], "]"}]}], ";",
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"d", "<", 
           RowBox[{"10", "^", 
            RowBox[{"-", "3"}]}]}], ",", 
          RowBox[{"Vmin", "=", "V"}], ",", 
          RowBox[{"Vmax", "=", "V"}]}], "]"}], ";"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"x", "[", "iMu", "]"}], "=", "Mu"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"y", "[", "iMu", "]"}], "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Vmin", "+", "Vmax"}], ")"}], "/", "2"}]}], ";"}]}], "]"}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"phase", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"y", "[", "iMu", "]"}], ",", 
       RowBox[{"x", "[", "iMu", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"iMu", ",", "0", ",", "nMu"}], "}"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\n", 
 RowBox[{"ListPlot", "[", 
  RowBox[{"phase", ",", 
   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1.5", ",", "3.5"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "4.0"}], ",", "3.0"}], "}"}]}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "okay", " ", "now", " ", "FEt", " ", "is", " ", "working", " ", "for", " ", 
     RowBox[{"both", "!"}], " ", "convergence", " ", "condition", " ", 
     "instantly", " ", "met", " ", "for", " ", "more", " ", "runs", " ", "so",
      " ", "stops", " ", "bisection"}], ",", " ", 
    RowBox[{
    "would", " ", "have", " ", "to", " ", "make", " ", "larger", " ", "for", " ",
      "more", " ", "runs"}], ",", " ", 
    RowBox[{
    "could", " ", "calculate", " ", "rough", " ", "estimate", " ", "if", " ", 
     "had", " ", "more", " ", "time"}]}], " ", "*)"}]}]}], "Input",
