Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Tmin", "=", "0.2"}], ";", 
  RowBox[{"Tmax", "=", "1.5"}], ";", 
  RowBox[{"Vmin", "=", "1.5"}], ";", 
  RowBox[{"Vmax", "=", "3.5"}], ";", 
  RowBox[{"ng", "=", "40"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"i", "=", "0"}], ",", 
   RowBox[{"i", "<=", "ng"}], ",", 
   RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"j", "=", "0"}], ",", 
      RowBox[{"j", "<=", "ng"}], ",", 
      RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"V", "=", 
        RowBox[{"Vmin", "+", 
         RowBox[{
          RowBox[{"i", "/", "ng"}], "*", 
          RowBox[{"(", 
           RowBox[{"Vmax", "-", "Vmin"}], ")"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"T", "=", 
        RowBox[{"Tmin", "+", 
         RowBox[{
          RowBox[{"j", "/", "ng"}], "*", 
          RowBox[{"(", 
           RowBox[{"Tmax", "-", "Tmin"}], ")"}]}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"del", "=", "0.0000000001"}], ";", 
       RowBox[{"mit", "=", "20"}], ";", 
       RowBox[{"pa", "=", "0.05"}], ";", 
       RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"m", "=", "0"}], ",", 
         RowBox[{"m", "<=", "mit"}], ",", 
         RowBox[{"m", "++"}], ",", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
          RowBox[{
           RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"dfta", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"FEt", "[", 
               RowBox[{
                RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
              RowBox[{"FEt", "[", 
               RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"dftb", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"FEt", "[", 
               RowBox[{"pa", ",", 
                RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
              RowBox[{"FEt", "[", 
               RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"pa", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"dftb", "-", 
               RowBox[{"2", " ", "dfta"}]}], ")"}], "/", "6"}], "/", "V"}]}], 
          ";", "\[IndentingNewLine]", 
          RowBox[{"pb", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"dfta", "-", 
               RowBox[{"2", " ", "dftb"}]}], ")"}], "/", "6"}], "/", "V"}]}], 
          ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"a", "[", "20", "]"}], "]"}], "<", 
          RowBox[{"Abs", "[", 
           RowBox[{"a", "[", "5", "]"}], "]"}]}], ",", 
         RowBox[{
          RowBox[{"phase", "[", 
           RowBox[{"i", ",", "j"}], "]"}], "=", "0"}], ",", 
         RowBox[{
          RowBox[{"phase", "[", 
           RowBox[{"i", ",", "j"}], "]"}], "=", "1"}]}], "]"}]}]}], 
     "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"100.", "*", 
      RowBox[{"i", "/", "ng"}]}], "]"}]}]}], "\[IndentingNewLine]", 
  "]"}]}], "Input",
