Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"plotting", " ", "T", " ", "against", " ", "V"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"mu", "=", 
     RowBox[{"-", "0.5"}]}], ";", 
    RowBox[{"Tmin", "=", "0.2"}], ";", 
    RowBox[{"Tmax", "=", "1.4"}], ";", 
    RowBox[{"nT", "=", "5"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"iT", "=", "0"}], ",", 
     RowBox[{"iT", "<=", "nT"}], ",", 
     RowBox[{"iT", "++"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"T", "=", 
       RowBox[{"Tmin", "+", 
        RowBox[{
         RowBox[{"iT", "/", "nT"}], "*", 
         RowBox[{"(", 
          RowBox[{"Tmax", "-", "Tmin"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Vmin", "=", "2.0"}], ";", 
      RowBox[{"Vmax", "=", "4.0"}], ";", 
      RowBox[{"nb", "=", "10"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"ib", "=", "1"}], ",", 
        RowBox[{"ib", "<=", "nb"}], ",", 
        RowBox[{"ib", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"V", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Vmin", "+", "Vmax"}], ")"}], "/", "2"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"del", "=", "0.0000000001"}], ";", 
         RowBox[{"mit", "=", "20"}], ";", 
         RowBox[{"pa", "=", "0.05"}], ";", 
         RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"m", "=", "0"}], ",", 
           RowBox[{"m", "<=", "mit"}], ",", 
           RowBox[{"m", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
            RowBox[{
             RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"dfta", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{
                  RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"dftb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", 
                  RowBox[{"pb", "+", "del"}]}], "]"}], "-", 
                RowBox[{"FEt", "[", 
                 RowBox[{"pa", ",", "pb"}], "]"}]}], ")"}], "/", "del"}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"pa", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"dftb", "-", 
                 RowBox[{"2", " ", "dfta"}]}], ")"}], "/", "6"}], "/", 
              "V"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"pb", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"dfta", "-", 
                 RowBox[{"2", " ", "dftb"}]}], ")"}], "/", "6"}], "/", 
              "V"}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", 
             RowBox[{"a", "[", "60", "]"}], "]"}], "<", 
            RowBox[{"Abs", "[", 
             RowBox[{"a", "[", "5", "]"}], "]"}]}], ",", 
           RowBox[{"Vmin", "=", "V"}], ",", 
           RowBox[{"Vmax", "=", "V"}]}], "]"}]}]}], "\[IndentingNewLine]", 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "[", "iT", "]"}], "=", "T"}], ";", "\[IndentingNewLine]", 
      
      RowBox[{
       RowBox[{"y", "[", "iT", "]"}], "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vmin", "+", "Vmax"}], ")"}], "/", "2"}]}]}]}], 
    "\[IndentingNewLine]", "]"}]}]}]], "Input",
