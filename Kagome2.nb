Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "="}], 
   "*)"}], 
  RowBox[{"(*", 
   RowBox[{"mu", "-", 
    RowBox[{"V", " ", "phase", " ", "diagram"}]}], "*)"}], 
  RowBox[{"(*", 
   RowBox[{"fixed", " ", "T"}], "*)"}], 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"===", "===", "===", "===", "===", "===", "===", "==="}], "="}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"TFixed", "=", "0.4"}], ";"}], "   ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"change", " ", "to", " ", "0.6"}], ",", "1.0", ",", 
     RowBox[{"etc", "."}]}], "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"muMin", "=", 
     RowBox[{"-", "4.0"}]}], ";", 
    RowBox[{"muMax", "=", "2.0"}], ";", 
    RowBox[{"nMu", "=", "120"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"VMin", "=", "1.0"}], ";", 
    RowBox[{"VMax", "=", "6.0"}], ";", 
    RowBox[{"nV", "=", "120"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"del", "=", 
     RowBox[{"10", "^", 
      RowBox[{"-", "6"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mit", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"ordCut", "=", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "build"}]}], " ", "explicit", " ", 
     RowBox[{
      RowBox[{"grids", "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"muVals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"muMin", "+", 
        RowBox[{
         RowBox[{"i", "/", "nMu"}], " ", 
         RowBox[{"(", 
          RowBox[{"muMax", "-", "muMin"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", "nMu"}], "}"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"vVals", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"VMin", "+", 
        RowBox[{
         RowBox[{"j", "/", "nV"}], " ", 
         RowBox[{"(", 
          RowBox[{"VMax", "-", "VMin"}], ")"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "0", ",", "nV"}], "}"}]}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "fixed"}]}], " ", 
     RowBox[{
      RowBox[{"temperature", "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"T", "=", "TFixed"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"--", 
      RowBox[{"--", "phase"}]}], " ", "map", " ", "on", " ", 
     RowBox[{"(", 
      RowBox[{"V", ",", "mu"}], ")"}], " ", 
     RowBox[{
      RowBox[{"grid", "--"}], "--"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phasePlotMuV", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"mu", "=", 
           RowBox[{"muVals", "[", 
            RowBox[{"[", 
             RowBox[{"i", "+", "1"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"V", "=", 
           RowBox[{"vVals", "[", 
            RowBox[{"[", 
             RowBox[{"j", "+", "1"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"pa", "=", "0.05"}], ";", "\[IndentingNewLine]", 
          RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"m", "=", "0"}], ",", 
            RowBox[{"m", "<=", "mit"}], ",", 
            RowBox[{"m", "++"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"f00", "=", 
              RowBox[{"FEt", "[", 
               RowBox[{"pa", ",", "pb"}], "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"fa", "=", 
              RowBox[{"FEt", "[", 
               RowBox[{
                RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"fb", "=", 
              RowBox[{"FEt", "[", 
               RowBox[{"pa", ",", 
                RowBox[{"pb", "+", "del"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"dfta", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"fa", "-", "f00"}], ")"}], "/", "del"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"dftb", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"fb", "-", "f00"}], ")"}], "/", "del"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"pa", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"dftb", "-", 
                 RowBox[{"2", " ", "dfta"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"6", " ", "V"}], ")"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"pb", "=", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"dfta", "-", 
                 RowBox[{"2", " ", "dftb"}]}], ")"}], "/", 
               RowBox[{"(", 
                RowBox[{"6", " ", "V"}], ")"}]}]}], ";"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"ord", "=", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"pa", "^", "2"}], "+", 
             RowBox[{"pb", "^", "2"}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"pa", "+", "pb"}], ")"}], "^", "2"}]}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"crit", "=", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"ord", ">", "ordCut"}], ",", "1", ",", "0"}], "]"}]}], ";",
           "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"V", ",", "mu", ",", "crit"}], "}"}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "0", ",", "nMu"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "0", ",", "nV"}], "}"}]}], "]"}], ",", "1"}], 
      "]"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"--", 
     RowBox[{"--", 
      RowBox[{
       RowBox[{"plot", "--"}], "--"}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ListDensityPlot", "[", 
    RowBox[{"phasePlotMuV", ",", 
