Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"muFixed", "=", 
    RowBox[{"-", "4.0"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Tmin", "=", "0.1"}], ";", 
   RowBox[{"Tmax", "=", "1.4"}], ";", 
   RowBox[{"nT", "=", "60"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"VbisMin", "=", "10.0"}], ";", 
  RowBox[{"VbisMax", "=", "25.0"}], ";", 
  RowBox[{"nbis", "=", "10"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Vplotmin", "=", "10.0"}], ";", 
   RowBox[{"Vplotmax", "=", "25.0"}], ";", 
   RowBox[{"nV", "=", "120"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{"del", "=", 
   RowBox[{"10", "^", 
    RowBox[{"-", "6"}]}]}], ";", 
  RowBox[{"mit", "=", "40"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"ordCut", "=", 
    RowBox[{"10", "^", 
     RowBox[{"-", "3"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Step"}]}], " ", "1"}], ":", 
    RowBox[{
     RowBox[{"critical", " ", "line", " ", "Vc", 
      RowBox[{"(", "T", ")"}], " ", "by", " ", "bisection", " ", "at", " ", 
      "fixed", " ", 
      RowBox[{"mu", "--"}]}], "-"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"iT", "=", "0"}], ",", 
     RowBox[{"iT", "<=", "nT"}], ",", 
     RowBox[{"iT", "++"}], ",", 
     RowBox[{
      RowBox[{"T", "=", 
       RowBox[{"Tmin", "+", 
        RowBox[{
         RowBox[{"iT", "/", "nT"}], " ", 
         RowBox[{"(", 
          RowBox[{"Tmax", "-", "Tmin"}], ")"}]}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mu", "=", "muFixed"}], ";", "\[IndentingNewLine]", 
      RowBox[{"v1", "=", "VbisMin"}], ";", "\[IndentingNewLine]", 
      RowBox[{"v2", "=", "VbisMax"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"ib", "=", "1"}], ",", 
        RowBox[{"ib", "<=", "nbis"}], ",", 
        RowBox[{"ib", "++"}], ",", 
        RowBox[{
         RowBox[{"V", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"v1", "+", "v2"}], ")"}], "/", "2"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"pa", "=", "0.05"}], ";", "\[IndentingNewLine]", 
         RowBox[{"pb", "=", "0.01"}], ";", "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"m", "=", "0"}], ",", 
           RowBox[{"m", "<=", "mit"}], ",", 
           RowBox[{"m", "++"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"a", "[", "m", "]"}], "=", "pa"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"b", "[", "m", "]"}], "=", "pb"}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"f00", "=", 
             RowBox[{"FEt", "[", 
              RowBox[{"pa", ",", "pb"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"fa", "=", 
             RowBox[{"FEt", "[", 
              RowBox[{
               RowBox[{"pa", "+", "del"}], ",", "pb"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"fb", "=", 
             RowBox[{"FEt", "[", 
              RowBox[{"pa", ",", 
               RowBox[{"pb", "+", "del"}]}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"dfta", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"fa", "-", "f00"}], ")"}], "/", "del"}]}], ";", " ", 
            "\[IndentingNewLine]", 
            RowBox[{"dftb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"fb", "-", "f00"}], ")"}], "/", "del"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"pa", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"dftb", "-", 
                RowBox[{"2", " ", "dfta"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"6", " ", "V"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"pb", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"dfta", "-", 
                RowBox[{"2", " ", "dftb"}]}], ")"}], "/", 
              RowBox[{"(", 
               RowBox[{"6", " ", "V"}], ")"}]}]}], ";"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"ord", "=", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"pa", "^", "2"}], "+", 
            RowBox[{"pb", "^", "2"}], "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"pa", "+", "pb"}], ")"}], "^", "2"}]}], "]"}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"crit", "=", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"ord", ">", "ordCut"}], ",", "1", ",", "0"}], "]"}]}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"crit", "==", "1"}], ",", 
           RowBox[{"v2", "=", "V"}], ",", 
           RowBox[{"v1", "=", "V"}]}], "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"tVal", "[", "iT", "]"}], "=", "T"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Vc", "[", "iT", "]"}], "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"v1", "+", "v2"}], ")"}], "/", "2"}]}], ";"}]}], "]"}], 
   ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"--", 
      RowBox[{"-", "Step"}]}], " ", "2"}], ":", 
    RowBox[{
     RowBox[{"explicit", " ", 
      RowBox[{"arrays", "--"}]}], "-"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tVals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"tVal", "[", "i", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "0", ",", "nT"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"vcVals", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"Vc", "[", "i", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "0", ",", "nT"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vVals", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Vplotmin", "+", 
       RowBox[{
        RowBox[{"j", "/", "nV"}], " ", 
        RowBox[{"(", 
         RowBox[{"Vplotmax", "-", "Vplotmin"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "0", ",", "nV"}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"--", 
        RowBox[{"-", "Step"}]}], " ", "3"}], ":", 
      RowBox[{"phase", " ", "map", " ", "with", " ", "axes", " ", "x"}]}], "=",
      "V"}], ",", 
    RowBox[{"y", "=", 
     RowBox[{
      RowBox[{"T", "--"}], "-"}]}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"phasePlotVT4", "=", 
    RowBox[{"Flatten", "[", 
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"vVals", "[", 
           RowBox[{"[", 
            RowBox[{"j", "+", "1"}], "]"}], "]"}], ",", 
          RowBox[{"tVals", "[", 
           RowBox[{"[", 
            RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"vVals", "[", 
              RowBox[{"[", 
               RowBox[{"j", "+", "1"}], "]"}], "]"}], ">=", 
             RowBox[{"vcVals", "[", 
              RowBox[{"[", 
               RowBox[{"i", "+", "1"}], "]"}], "]"}]}], ",", "1", ",", "0"}], 
           "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "0", ",", "nT"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "0", ",", "nV"}], "}"}]}], "]"}], ",", "1"}], 
     "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"critLineT", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"tVals", "[", 
         RowBox[{"[", 
          RowBox[{"i", "+", "1"}], "]"}], "]"}], ",", 
        RowBox[{"vcVals", "[", 
         RowBox[{"[", 
          RowBox[{"i", "+", "1"}], "]"}], "]"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "0", ",", "nT"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"tFine", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"Tmin", "+", 
       RowBox[{
        RowBox[{"s", "/", "400."}], " ", 
        RowBox[{"(", 
         RowBox[{"Tmax", "-", "Tmin"}], ")"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "400"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"ListDensityPlot", "[", 
  RowBox[{"phasePlotVT4", ",", 
   RowBox[{"InterpolationOrder", "->", "0"}], ",", 
   RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", "==", "1"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.94", ",", "0.89", ",", "0.67"}], "]"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.10", ",", "0.15", ",", "0.55"}], "]"}]}], "]"}], "&"}], 
     ")"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<\[Mu] = -4.0\>\""}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<V\>\"", ",", "15"}], "]"}], ",", 
      RowBox[{"Rotate", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<T\>\"", ",", "15"}], "]"}], ",", 
