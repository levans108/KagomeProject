Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListDensityPlot", "[", 
  RowBox[{"phasePlotVT5", ",", 
   RowBox[{"InterpolationOrder", "->", "0"}], ",", 
   RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", "==", "1"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.94", ",", "0.89", ",", "0.67"}], "]"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.10", ",", "0.15", ",", "0.55"}], "]"}]}], "]"}], "&"}], 
     ")"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<\[Mu] = 2.0\>\""}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<V\>\"", ",", "15"}], "]"}], ",", 
      RowBox[{"Rotate", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<T\>\"", ",", "15"}], "]"}], ",", 
        RowBox[{
         RowBox[{"-", "Pi"}], "/", "2"}]}], "]"}]}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"14", ",", "Black"}], "]"}]}], ",", 
   RowBox[{"FrameStyle", "->", 
    RowBox[{"Directive", "[", 
     RowBox[{"Black", ",", "12"}], "]"}]}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Vplotmin", ",", "Vplotmax"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Tmin", ",", "Tmax"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"ImageSize", "->", "500"}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<CDW\>\"", ",", "16", ",", "Bold", ",", "Black"}], "]"}],
         ",", 
        RowBox[{"{", 
         RowBox[{"3.0", ",", "0.3"}], "}"}]}], "]"}], ",", 
      RowBox[{"Text", "[", 
