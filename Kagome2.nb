     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<V\>\"", ",", "15"}], "]"}], ",", 
      RowBox[{"Rotate", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
