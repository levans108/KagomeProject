    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"11", ",", "22"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"Tmin", ",", "Tmax"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"AspectRatio", "->", "1"}], ",", 
   RowBox[{"ImageSize", "->", "500"}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Text", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<CDW\>\"", ",", "16", ",", "Bold", ",", "Black"}], "]"}],
