      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "400"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{"ListDensityPlot", "[", 
  RowBox[{"phasePlotVT4", ",", 
