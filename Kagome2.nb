  RowBox[{"phasePlotMuV", ",", 
   RowBox[{"InterpolationOrder", "->", "0"}], ",", 
   RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", "==", "1"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.94", ",", "0.89", ",", "0.67"}], "]"}], ",", 
        RowBox[{"(*", "CDW", "*)"}], 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.10", ",", "0.15", ",", "0.55"}], "]"}]}], "    ", 
       RowBox[{"(*", "Disordered", "*)"}], "]"}], "&"}], ")"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
