Cell[BoxData[
 RowBox[{"ListDensityPlot", "[", 
  RowBox[{"phasePlotVT4", ",", 
   RowBox[{"InterpolationOrder", "->", "0"}], ",", 
   RowBox[{"ColorFunctionScaling", "->", "False"}], ",", 
   RowBox[{"ColorFunction", "->", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"#", "==", "1"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.94", ",", "0.89", ",", "0.67"}], "]"}], ",", 
        RowBox[{"RGBColor", "[", 
         RowBox[{"0.10", ",", "0.15", ",", "0.55"}], "]"}]}], "]"}], "&"}], 
     ")"}]}], ",", 
   RowBox[{"Frame", "->", "True"}], ",", 
   RowBox[{"PlotLabel", "->", "\"\<\[Mu] = -4.0\>\""}], ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Style", "[", 
       RowBox[{"\"\<V\>\"", ",", "15"}], "]"}], ",", 
      RowBox[{"Rotate", "[", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<T\>\"", ",", "15"}], "]"}], ",", 
        RowBox[{
         RowBox[{"-", "Pi"}], "/", "2"}]}], "]"}]}], "}"}]}], ",", 
   RowBox[{"LabelStyle", "->", 
