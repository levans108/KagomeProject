        RowBox[{"{", 
         RowBox[{"kx", ",", 
          RowBox[{"-", "3"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"ky", ",", "0"}], "}"}]}], "}"}]}], "]"}]}], "\n", 
   RowBox[{"sol3", "=", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"dE2dkx", "[", 
          RowBox[{"kx", ",", "ky"}], "]"}], "==", "0"}], ",", 
