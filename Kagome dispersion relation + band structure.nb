Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"grid", " ", "resolution"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"nk", "=", "200"}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"kxVals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"-", "Pi"}], ",", "Pi", ",", "nk"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kyVals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"-", "Pi"}], ",", "Pi", ",", "nk"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"numerically", " ", "solved"}], ",", " ", 
     RowBox[{
     "essentially", " ", "want", " ", "to", " ", "input", " ", "value", " ", 
      "as", " ", "probability", " ", "distribution"}], ",", " ", 
     RowBox[{"try", " ", "as", " ", "normal", " ", "distribution"}]}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energies", "=", 
     RowBox[{
      RowBox[{"Reap", "[", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "kxVals", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"j", "=", "1"}], ",", 
           RowBox[{"j", "<=", 
            RowBox[{"Length", "[", "kyVals", "]"}]}], ",", 
           RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"kx", "=", 
             RowBox[{"kxVals", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"ky", "=", 
             RowBox[{"kyVals", "[", 
              RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"vals", "=", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"E2", "[", 
                RowBox[{"kx", ",", "ky"}], "]"}], ",", 
               RowBox[{"E3", "[", 
                RowBox[{"kx", ",", "ky"}], "]"}]}], "}"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "4"}], "t"}], "<=", "x", "<=", 
                 RowBox[{"2", "t"}]}], ",", 
                RowBox[{"Sow", "[", "x", "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "vals"}], "}"}]}], "]"}], ";"}]}], 
          "\[IndentingNewLine]", "]"}]}], "]"}], "\n", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"2", ",", "1"}], "]"}], "]"}]}], ";"}], " "}]}]], "Input",
