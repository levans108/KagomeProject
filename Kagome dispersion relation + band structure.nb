Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"parameters", " ", "and", " ", "evalues"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", "parameters", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"t", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"a", "=", "1.0"}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "bands", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E1", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"2", " ", "t"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E2", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"3", "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "kx"}], "/", "2"}], "+", 
               RowBox[{
                RowBox[{"Sqrt", "[", "3", "]"}], " ", 
                RowBox[{"ky", "/", "2"}]}]}], ")"}]}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "kx"}], "/", "2"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}], " ", 
                RowBox[{"ky", "/", "2"}]}]}], ")"}]}], "]"}]}]}], "]"}]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E3", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "-", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"3", "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "kx"}], "/", "2"}], "+", 
               RowBox[{
                RowBox[{"Sqrt", "[", "3", "]"}], " ", 
                RowBox[{"ky", "/", "2"}]}]}], ")"}]}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "kx"}], "/", "2"}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}], " ", 
                RowBox[{"ky", "/", "2"}]}]}], ")"}]}], "]"}]}]}], "]"}]}], 
       ")"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"k", "-", "grid"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"nk", "=", "600"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kxVals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"-", "Pi"}], ",", "Pi", ",", "nk"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"kyVals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{
       RowBox[{"-", "Pi"}], ",", "Pi", ",", "nk"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"sample", " ", "all", " ", "bands"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energiesAll", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"E1", "[", 
            RowBox[{"kx", ",", "ky"}], "]"}], ",", 
           RowBox[{"E2", "[", 
            RowBox[{"kx", ",", "ky"}], "]"}], ",", 
           RowBox[{"E3", "[", 
            RowBox[{"kx", ",", "ky"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"kx", ",", "kxVals"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"ky", ",", "kyVals"}], "}"}]}], "]"}], ",", "2"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "sample", " ", "only", " ", "dispersive", " ", "bands", " ", "if", " ", 
      "you", " ", "want", " ", "the", " ", "smooth", " ", "orange"}], "-", 
     RowBox[{"shaped", " ", "DOS"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"energiesDisp", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"E2", "[", 
            RowBox[{"kx", ",", "ky"}], "]"}], ",", 
           RowBox[{"E3", "[", 
            RowBox[{"kx", ",", "ky"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"kx", ",", "kxVals"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"ky", ",", "kyVals"}], "}"}]}], "]"}], ",", "2"}], "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Gaussian", " ", "broadening"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Eta]", "=", "0.025"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"gauss", "[", "x_", "]"}], ":=", 
     RowBox[{
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"x", "^", "2"}]}], "/", 
        RowBox[{"(", 
         RowBox[{"2", " ", 
          RowBox[{"\[Eta]", "^", "2"}]}], ")"}]}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", "Pi"}], "]"}], " ", "\[Eta]"}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Emin", "=", 
     RowBox[{"-", "4.1"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Emax", "=", "2.03"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"eVals", "=", 
     RowBox[{"Subdivide", "[", 
      RowBox[{"Emin", ",", "Emax", ",", "800"}], "]"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", "DOS", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"dosDisp", "=", 
     RowBox[{"Mean", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"gauss", "[", 
         RowBox[{"eVals", "-", "#"}], "]"}], "&"}], "/@", "energiesDisp"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "remove", " ", "Gaussian", " ", "tail", " ", "above", " ", "the", " ", 
     "flat", " ", "band"}], "*)"}], 
   RowBox[{
    RowBox[{"dosDispClipped", "=", 
     RowBox[{"MapThread", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"#2", "<=", "2"}], ",", "#1", ",", "0"}], "]"}], "&"}], ",", 
       RowBox[{"{", 
        RowBox[{"dosDisp", ",", "eVals"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"optional", ":", 
     RowBox[{
     "set", " ", "tiny", " ", "values", " ", "to", " ", "zero", " ", "for", " ",
       "cleaner", " ", "presentation"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"cutoff", "=", 
     RowBox[{"5", "*", 
      RowBox[{"10", "^", 
       RowBox[{"-", "4"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"dosClean", "=", 
     RowBox[{"dosDispClipped", "/.", " ", 
      RowBox[{
       RowBox[{"x_", "/;", 
        RowBox[{"x", "<", "cutoff"}]}], "->", "0"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"dispData", "=", 
     RowBox[{"Transpose", "[", 
      RowBox[{"{", 
       RowBox[{"dosClean", ",", "eVals"}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"xmax", "=", 
     RowBox[{"Max", "[", 
      RowBox[{"dispData", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"Show", "[", 
    RowBox[{
     RowBox[{"ListLinePlot", "[", 
      RowBox[{"dispData", ",", 
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Thick", ",", "Red"}], "}"}]}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Style", "[", 
           RowBox[{"\"\<D(E)\>\"", ",", "Bold"}], "]"}], ",", 
          RowBox[{"Style", "[", 
           RowBox[{"\"\<E/t\>\"", ",", "Bold"}], "]"}]}], "}"}]}], ",", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "All"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "5"}], ",", "3"}], "}"}]}], "}"}]}], ",", 
       RowBox[{"AspectRatio", "->", "1"}], ",", 
       RowBox[{"ImageSize", "->", "350"}]}], "]"}], ",", 
     RowBox[{"Graphics", "[", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Red", ",", 
        RowBox[{"Line", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "1.9999"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"Max", "[", 
               RowBox[{"dispData", "[", 
                RowBox[{"[", 
                 RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], "*", 
              "1.05"}], ",", "2"}], "}"}]}], "}"}], "]"}]}], "}"}], "]"}]}], 
    "]"}]}]}]], "Input",
