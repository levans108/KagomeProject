  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
  "\n", 
  RowBox[{"(*", "Parameters", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "=", "1.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tHop", "=", "1.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kxK", "=", 
   RowBox[{"-", "0.280596"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"kyK", "=", "1.0472"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"kxM", "=", "2.7207"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"kyM", "=", "1.5708"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"\[CapitalGamma]", "->", "K"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"k1", "[", "s_", "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"s", " ", "kxK"}], ",", 
      RowBox[{"s", " ", "kyK"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"K", "->", "M"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"k2", "[", "s_", "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"kxK", "+", 
       RowBox[{"s", " ", 
        RowBox[{"(", 
         RowBox[{"kxM", "-", "kxK"}], ")"}]}]}], ",", 
      RowBox[{"kyK", "+", 
       RowBox[{"s", " ", 
        RowBox[{"(", 
         RowBox[{"kyM", "-", "kyK"}], ")"}]}]}]}], "}"}]}], ";"}], "\n", 
  RowBox[{"(*", 
   RowBox[{"M", "->", "\[CapitalGamma]"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"k3", "[", "s_", "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"kxM", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "s"}], ")"}]}], ",", 
      RowBox[{"kyM", " ", 
       RowBox[{"(", 
        RowBox[{"1", "-", "s"}], ")"}]}]}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Arc", "-", 
    RowBox[{"length", " ", "positions", " ", "for", " ", "x"}], "-", "axis"}],
    "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"L1", "=", "1.0"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"L2", "=", "0.55"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"L3", "=", "1.0"}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x1", "[", "s_", "]"}], ":=", 
   RowBox[{"s", " ", "L1"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"x2", "[", "s_", "]"}], ":=", 
   RowBox[{"L1", "+", 
    RowBox[{"s", " ", "L2"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"x3", "[", "s_", "]"}], ":=", 
    RowBox[{"L1", "+", "L2", "+", 
     RowBox[{"s", " ", "L3"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Kagome", " ", "dispersion"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Eflat", "[", 
    RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
   RowBox[{"2", " ", "tHop"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Eplus", "[", 
     RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
    RowBox[{"tHop", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"3", "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
              RowBox[{"ky", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}]}]}], ")"}]}], 
           "]"}]}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
              RowBox[{"ky", " ", "0.5", " ", 
               RowBox[{"(", 
                RowBox[{"2", "+", 
                 RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}]}], ")"}]}], 
           "]"}]}]}], "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Eminus", "[", 
     RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
    RowBox[{"tHop", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "-", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"3", "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
              RowBox[{"ky", " ", 
               RowBox[{
                RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}]}]}], ")"}]}], 
           "]"}]}], "+", 
         RowBox[{"2", " ", 
          RowBox[{"Cos", "[", 
           RowBox[{"2", " ", "a", " ", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
              RowBox[{"ky", " ", "0.5", " ", 
               RowBox[{"(", 
                RowBox[{"2", "+", 
                 RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}]}], ")"}]}], 
           "]"}]}]}], "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "Sample", " ", "points", " ", "along", " ", "each", " ", "segment"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"n", "=", "300"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"seg1", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"k", "=", 
          RowBox[{"k1", "[", "s", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x1", "[", "s", "]"}], ",", 
          RowBox[{"Eflat", "@@", "k"}], ",", 
          RowBox[{"Eplus", "@@", "k"}], ",", 
          RowBox[{"Eminus", "@@", "k"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "1", ",", 
        RowBox[{"1.0", "/", "n"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"seg2", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"k", "=", 
          RowBox[{"k2", "[", "s", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x2", "[", "s", "]"}], ",", 
          RowBox[{"Eflat", "@@", "k"}], ",", 
          RowBox[{"Eplus", "@@", "k"}], ",", 
          RowBox[{"Eminus", "@@", "k"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "1", ",", 
        RowBox[{"1.0", "/", "n"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"seg3", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"k", "=", 
          RowBox[{"k3", "[", "s", "]"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"x3", "[", "s", "]"}], ",", 
          RowBox[{"Eflat", "@@", "k"}], ",", 
          RowBox[{"Eplus", "@@", "k"}], ",", 
          RowBox[{"Eminus", "@@", "k"}]}], "}"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"s", ",", "0", ",", "1", ",", 
        RowBox[{"1.0", "/", "n"}]}], "}"}]}], "]"}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"data", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"seg1", ",", "seg2", ",", "seg3"}], "]"}]}], " ", ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Vertical", " ", "separator", " ", "positions"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"xK", "=", "L1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"xM", "=", 
   RowBox[{"L1", "+", "L2"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"xG2", "=", 
    RowBox[{"L1", "+", "L2", "+", "L3"}]}], ";"}], "\[IndentingNewLine]"}], "\n", 
