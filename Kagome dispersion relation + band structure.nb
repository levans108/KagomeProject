Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "define", " ", "eigenvlues", " ", "for", " ", "DP", " ", "and", " ", "VHs",
     " ", "investigation"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"t", "=", "1.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"a", "=", "1.0"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E1", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"2", " ", "t"}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E2", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"3", "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
               RowBox[{"ky", " ", 
                RowBox[{
                 RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}]}]}], ")"}]}], 
            "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
               RowBox[{"ky", " ", "0.5", " ", 
                RowBox[{"(", 
                 RowBox[{"2", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}]}], ")"}]}], 
            "]"}]}]}], "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"E3", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "-", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"3", "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", "ky"}], "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
               RowBox[{"ky", " ", 
                RowBox[{
                 RowBox[{"Sqrt", "[", "3", "]"}], "/", "2"}]}]}], ")"}]}], 
            "]"}]}], "+", 
          RowBox[{"2", " ", 
           RowBox[{"Cos", "[", 
            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
               RowBox[{"ky", " ", "0.5", " ", 
                RowBox[{"(", 
                 RowBox[{"2", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}]}], ")"}]}], 
            "]"}]}]}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]"}]}]], "Input",
