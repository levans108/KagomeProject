   RowBox[{"sol2", "=", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"dE2dkx", "[", 
          RowBox[{"kx", ",", "ky"}], "]"}], "==", "0"}], ",", 
        RowBox[{
         RowBox[{"dE2dky", "[", 
          RowBox[{"kx", ",", "ky"}], "]"}], "==", "0"}]}], "}"}], ",", 
