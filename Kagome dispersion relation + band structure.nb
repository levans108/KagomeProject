            RowBox[{"2", " ", "a", " ", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"-", "0.5"}], " ", "kx"}], "+", 
               RowBox[{"ky", " ", "0.5", " ", 
                RowBox[{"(", 
                 RowBox[{"2", "+", 
                  RowBox[{"Sqrt", "[", "3", "]"}]}], ")"}]}]}], ")"}]}], 
            "]"}]}]}], "]"}]}], ")"}]}]}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"E3", "[", 
      RowBox[{"kx_", ",", "ky_"}], "]"}], ":=", 
     RowBox[{"t", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "1"}], "-", 
        RowBox[{"Sqrt", "[", 
