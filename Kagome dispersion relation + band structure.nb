Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "solving", " ", "equations", " ", "numerically", " ", "with", " ", 
    "guesses"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"sol1", "=", 
    RowBox[{"FindRoot", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"dE2dkx", "[", 
